{% extends 'base.html.twig' %}

{% block title %}Order index{% endblock %}

{% block body %}
    <h1>Order index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Status</th>
                <th>Type</th>
                <th>CreatedAt</th>
                <th>actions</th>
            </tr>
        </thead>

        <tbody>
        {% for order in orders %}
            <tr>
                <td>{{ order.id }}</td>
                <td>{{ order.status }}</td>
                <td>{{ order.type }}</td>
                <td>{{ order.createdAt ? order.createdAt|date('Y-m-d H:i:s') : '' }}</td>

                <td>
                    <a href="{{ path('app_order_show', {'id': order.id}) }}">show</a>

                    {# 🔐 ONLY WORKERS CAN EDIT #}
                    {% if is_granted('ROLE_WORKER') %}
                        <a href="{{ path('app_order_edit', {'id': order.id}) }}">edit</a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    {# 🔐 ONLY USERS (not workers) create orders if you want that rule #}
    {% if is_granted('ROLE_USER') and not is_granted('ROLE_WORKER') %}
        <a href="{{ path('app_order_new') }}">Create new</a>
    {% endif %}

{% endblock %}
