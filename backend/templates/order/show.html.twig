{% extends 'base.html.twig' %}

{% block title %}Order{% endblock %}

{% block body %}
    <h1>Order</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ order.id }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>{{ order.status }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>{{ order.type }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ order.createdAt ? order.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    {# 🍔 PRODUCTS #}
    <h2>Products</h2>
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Qty</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
        {% set total = 0 %}
        {% for line in order.orderLinesRef %}
            <tr>
                <td>{{ line.product.name }}</td>
                <td>{{ line.price }}</td>
                <td>{{ line.quantity }}</td>
                <td>{{ line.price * line.quantity }}</td>
            </tr>
            {% set total = total + (line.price * line.quantity) %}
        {% endfor %}
        </tbody>
    </table>

    <h3>Total: {{ total }}</h3>

    {# ✅ COMPLETE BUTTON (ONLY WORKER) #}
    {% if is_granted('ROLE_WORKER') and order.status != 'completed' %}
        <form method="post" action="{{ path('app_order_complete', {'id': order.id}) }}">
            <button class="btn btn-success">Complete Order</button>
        </form>
    {% endif %}

    <br>

    <a href="{{ path('app_order_index') }}">back to list</a>

    {% if is_granted('ROLE_WORKER') %}
        <a href="{{ path('app_order_edit', {'id': order.id}) }}">edit</a>
        {{ include('order/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}
