<h1>Invoice #{{ invoice.id }}</h1>

<p><strong>Customer:</strong> {{ invoice.user.email }}</p>

<p><strong>Order type:</strong> {{ invoice.orderRelation.type }}</p>

<p><strong>Status:</strong> {{ invoice.orderRelation.status }}</p>

<p><strong>Date:</strong> {{ invoice.createdAt|date('Y-m-d H:i') }}</p>

<hr>

<h3>Products</h3>

<ul>
    {% for line in invoice.orderRelation.orderLinesRef %}
        <li>
            {{ line.product.name }}
            — {{ line.quantity }} × {{ line.price }} €
            = {{ line.quantity * line.price }} €
        </li>
    {% endfor %}
</ul>

<hr>

<h2>Total: {{ invoice.total }} €</h2>
<a href="{{ path('app_invoice_pdf', {'id': invoice.id}) }}" target="_blank">
    Download PDF
</a>
